+from typing import Dict, Any, List
+from jsonschema import validate, ValidationError
+from .schema_stub import SCHEMA_STUB
+
+def detect_duplicate_ids(data: Dict[str, Any]) -> List[int]:
+    seen = set()
+    dup = []
+    for cat, subs in data.get("super_agent", {}).items():
+        for sub, items in subs.items():
+            for it in items:
+                i = it.get("id")
+                if i in seen:
+                    dup.append(i)
+                else:
+                    seen.add(i)
+    return dup
+
+def detect_missing_ids(data: Dict[str, Any], start: int = 1, end: int = 10000) -> List[int]:
+    seen = set()
+    for cat, subs in data.get("super_agent", {}).items():
+        for sub, items in subs.items():
+            for it in items:
+                seen.add(it.get("id"))
+    missing = [i for i in range(start, end + 1) if i not in seen]
+    return missing
+
+def validate_schema_minimal(data: Dict[str, Any]) -> List[str]:
+    errors = []
+    try:
+        validate(instance=data, schema=SCHEMA_STUB)
+    except ValidationError as e:
+        errors.append(str(e))
+    return errors
+
