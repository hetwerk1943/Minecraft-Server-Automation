+import os
+import traceback
+from uuid import uuid4
+from src.worker.celery_app import cel
+from src.worker.db import SessionLocal
+from src.worker.s3_uploader import upload_file
+from src.api.models import Job, Artifact
+from src.super_agent.generator import generate_and_write
+from src.super_agent.validator import detect_duplicate_ids, detect_missing_ids, validate_schema_minimal
+
+ARTIFACT_DIR = os.getenv("ARTIFACT_DIR", "/app/artefakty")
+
+@cel.task(bind=True, max_retries=2, default_retry_delay=10)
+def generate_job(self, tenant_id: int = None, partials_path: str = None, total: int = 10000):
+    job_id = uuid4().hex
+    session = SessionLocal()
+    job = Job(id=job_id, tenant_id=tenant_id, status="running")
+    session.add(job)
+    session.commit()
+    try:
+        os.makedirs(ARTIFACT_DIR, exist_ok=True)
+        local_path = os.path.join(ARTIFACT_DIR, f"super-agent-{job_id}.json")
+        generate_and_write(output_path=local_path, partials_path=partials_path, total_ids=total)
+        data = None
+        try:
+            from src.super_agent.io import load_json
+            data = load_json(local_path)
+        except Exception:
+            pass
+        dups = detect_duplicate_ids(data) if data else []
+        missing = detect_missing_ids(data) if data else []
+        schema_errs = validate_schema_minimal(data) if data else []
+        s3_key = f"{tenant_id or 'public'}/super-agent/{job_id}.json"
+        storage_url = upload_file(local_path, s3_key)
+        artifact = Artifact(tenant_id=tenant_id, job_id=job_id, s3_key=s3_key, storage_url=storage_url)
+        session.add(artifact)
+        job.status = "completed"
+        job.artifact_path = local_path
+        job.artifact_s3_key = s3_key
+        session.commit()
+        return {"job_id": job_id, "s3_key": s3_key, "storage_url": storage_url, "duplicates": dups[:20], "missing_sample": missing[:20], "schema_errors": schema_errs}
+    except Exception as exc:
+        session.rollback()
+        job.status = "failed"
+        job.error = f"{str(exc)}\n{traceback.format_exc()}"
+        session.add(job)
+        session.commit()
+        raise self.retry(exc=exc)
+    finally:
+        session.close()
+
