+from __future__ import annotations
+from typing import Dict, Any, List, Tuple
+from datetime import datetime
+from .io import load_json, write_json
+from .utils import normalize_entry
+
+DEFAULT_CATEGORIES_PATH = "configs/categories.json"
+
+def load_categories(path: str = DEFAULT_CATEGORIES_PATH) -> List[Dict[str, Any]]:
+    data = load_json(path)
+    return data.get("categories", [])
+
+def allocate_ranges(total: int, n_buckets: int) -> List[Tuple[int,int]]:
+    base = total // n_buckets
+    rem = total % n_buckets
+    ranges = []
+    cur = 1
+    for i in range(n_buckets):
+        size = base + (1 if i < rem else 0)
+        ranges.append((cur, cur + size - 1))
+        cur += size
+    return ranges
+
+def build_hierarchy_from_categories(categories: List[Dict[str,Any]], total_ids: int = 10000):
+    n = len(categories)
+    cat_ranges = allocate_ranges(total_ids, n)
+    buckets = []
+    for cat, (start, end) in zip(categories, cat_ranges):
+        subcats = cat.get("functions", []) or ["default"]
+        count = end - start + 1
+        per = count // len(subcats)
+        rem = count % len(subcats)
+        cur = start
+        for i, sub in enumerate(subcats):
+            size = per + (1 if i < rem else 0)
+            buckets.append({
+                "category": cat.get("name"),
+                "subcategory": sub,
+                "start": cur,
+                "end": cur + size - 1
+            })
+            cur += size
+    buckets.sort(key=lambda b: b["start"])
+    return buckets
+
+def find_bucket(buckets: List[Dict[str,Any]], idx: int):
+    for b in buckets:
+        if b["start"] <= idx <= b["end"]:
+            return b
+    return None
+
+def generate_from_partials(partials: Dict[int, Dict[str,Any]], categories_path: str = DEFAULT_CATEGORIES_PATH, total_ids: int = 10000, preview_limit: int = None) -> Dict[str,Any]:
+    categories = load_categories(categories_path)
+    buckets = build_hierarchy_from_categories(categories, total_ids=total_ids)
+    super_agent = {}
+    for b in buckets:
+        super_agent.setdefault(b["category"], {}).setdefault(b["subcategory"], [])
+
+    produced = 0
+    for i in range(1, total_ids + 1):
+        if preview_limit is not None and produced >= preview_limit:
+            break
+        if i in partials:
+            e = normalize_entry(partials[i])
+            e["id"] = int(i)
+            b = find_bucket(buckets, i)
+            e.setdefault("kategoria", b["category"] if b else "Unassigned")
+            e.setdefault("podkategoria", b["subcategory"] if b else "Unassigned")
+            super_agent[e["kategoria"]][e["podkategoria"]].append(e)
+            produced += 1
+            continue
+        b = find_bucket(buckets, i)
+        if b:
+            local_idx = i - b["start"] + 1
+            name = f"{b['subcategory']} — funkcja {local_idx}"
+            desc = f"{i}: {b['subcategory']} — automatyczna funkcja wygenerowana dla kategorii {b['category']}."
+            entry = {
+                "id": i,
+                "nazwa": name,
+                "opis": desc,
+                "kategoria": b["category"],
+                "podkategoria": b["subcategory"]
+            }
+            super_agent[b["category"]][b["subcategory"]].append(entry)
+        else:
+            entry = {"id": i, "nazwa": f"Funkcja {i}", "opis": "", "kategoria": "Unassigned", "podkategoria": "Unassigned"}
+            super_agent.setdefault("Unassigned", {}).setdefault("default", []).append(entry)
+        produced += 1
+
+    meta = {
+        "agent_name": "Ultimate Super-Agent",
+        "version": "1.0",
+        "description": "Hierarchiczny super-agent AI generowany programowo.",
+        "generated_at": datetime.utcnow().isoformat() + "Z",
+        "total_functions": produced
+    }
+    return {"meta": meta, "super_agent": super_agent}
+
+def generate_and_write(output_path: str, partials_path: str = None, categories_path: str = DEFAULT_CATEGORIES_PATH, total_ids: int = 10000, preview_limit: int = None):
+    partials = {}
+    if partials_path:
+        try:
+            raw = load_json(partials_path)
+            def traverse(o):
+                if isinstance(o, dict) and "id" in o:
+                    try:
+                        partials[int(o["id"])] = o
+                    except:
+                        pass
+                elif isinstance(o, dict):
+                    for v in o.values(): traverse(v)
+                elif isinstance(o, list):
+                    for el in o: traverse(el)
+            traverse(raw)
+        except Exception as e:
+            raise RuntimeError(f"Failed to load partials: {e}")
+    result = generate_from_partials(partials, categories_path=categories_path, total_ids=total_ids, preview_limit=preview_limit)
+    write_json(result, output_path)
+    return result
+
