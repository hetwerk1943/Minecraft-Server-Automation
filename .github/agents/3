+import os
+import boto3
+from botocore.exceptions import ClientError
+
+S3_ENDPOINT = os.getenv("S3_ENDPOINT", None)
+S3_ACCESS_KEY = os.getenv("S3_ACCESS_KEY", None)
+S3_SECRET_KEY = os.getenv("S3_SECRET_KEY", None)
+S3_BUCKET = os.getenv("S3_BUCKET", "ultra-agent-artifacts")
+
+def get_s3_client():
+    kwargs = {}
+    if S3_ENDPOINT:
+        kwargs["endpoint_url"] = S3_ENDPOINT
+    if S3_ACCESS_KEY and S3_SECRET_KEY:
+        kwargs["aws_access_key_id"] = S3_ACCESS_KEY
+        kwargs["aws_secret_access_key"] = S3_SECRET_KEY
+    return boto3.client("s3", **kwargs)
+
+def upload_file(local_path: str, key: str) -> str:
+    s3 = get_s3_client()
+    try:
+        s3.upload_file(local_path, S3_BUCKET, key)
+    except ClientError as e:
+        raise
+    if S3_ENDPOINT:
+        return f"{S3_ENDPOINT}/{S3_BUCKET}/{key}"
+    return f"s3://{S3_BUCKET}/{key}"
