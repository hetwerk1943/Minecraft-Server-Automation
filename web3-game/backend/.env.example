# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/assassin_game"

# JWT
JWT_SECRET=your-super-secret-key-minimum-256-bits
JWT_EXPIRES_IN=7d

# Blockchain
RPC_URL=https://polygon-rpc.com
CHAIN_ID=137
BLOCK_CONFIRMATIONS=3

# Contract Addresses
ASSASSIN_TOKEN_ADDRESS=
WEAPON_NFT_ADDRESS=
MOUNT_NFT_ADDRESS=
SKIN_NFT_ADDRESS=
MARKETPLACE_ADDRESS=
STAKING_ADDRESS=

# Redis
REDIS_URL=redis://localhost:6379

# IPFS
IPFS_API_KEY=
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Discord Webhooks (for alerts)
DISCORD_WEBHOOK_URL=

# Admin
ADMIN_ADDRESS=
ADMIN_PRIVATE_KEY=
